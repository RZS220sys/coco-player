<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:background="@drawable/bg_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="@dimen/icon_button_size"
            android:layout_height="@dimen/icon_button_size"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_back"
            android:padding="10dp"
            android:src="@drawable/ic_back_24" />

        <TextView
            android:id="@+id/title_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans"
            android:includeFontPadding="false"
            android:text="@string/screen_logs_title"
            android:textColor="@color/coco_title"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/refresh_button"
            android:layout_width="@dimen/icon_button_size"
            android:layout_height="@dimen/icon_button_size"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_refresh_logs"
            android:padding="10dp"
            android:src="@drawable/ic_refresh_24" />

        <TextView
            android:id="@+id/clear_button"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/bg_save_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="82dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/action_clear_logs"
            android:textColor="@color/coco_title"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        style="@style/CocoFormSection"
        android:layout_marginBottom="0dp">

        <TextView
            style="@style/CocoFieldLabel"
            android:paddingTop="0dp"
            android:text="@string/field_log_verbosity" />

        <TextView
            android:id="@+id/log_verbosity_select"
            style="@style/CocoFormSelect"
            android:text="warning" />

        <TextView
            style="@style/CocoFieldLabel"
            android:text="@string/field_search_logs" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_form_field">

            <EditText
                android:id="@+id/search_input"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:fontFamily="sans"
                android:hint="@string/field_search_logs_hint"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingEnd="48dp"
                android:singleLine="true"
                android:textColor="@color/coco_title"
                android:textColorHint="@color/coco_muted"
                android:textSize="15sp" />

            <ImageButton
                android:id="@+id/clear_search_button"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end|center_vertical"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_clear_search"
                android:padding="10dp"
                android:src="@drawable/ic_close_24"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/match_count_text"
            style="@style/CocoFieldHelp"
            android:text="@string/logs_line_count_zero" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="14dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="14dp"
        android:layout_weight="1"
        android:background="@drawable/bg_form_section">

        <ListView
            android:id="@+id/logs_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"
            android:fastScrollEnabled="true"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:scrollbars="vertical" />

        <TextView
            android:id="@+id/empty_logs_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="sans"
            android:gravity="center"
            android:includeFontPadding="false"
            android:padding="24dp"
            android:text="@string/logs_empty"
            android:textColor="@color/coco_muted"
            android:textSize="15sp" />
    </FrameLayout>
</LinearLayout>
