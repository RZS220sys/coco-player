<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:background="@drawable/bg_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="@dimen/icon_button_size"
            android:layout_height="@dimen/icon_button_size"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_back"
            android:padding="10dp"
            android:src="@drawable/ic_back_24" />

        <TextView
            android:id="@+id/title_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans"
            android:includeFontPadding="false"
            android:text="@string/screen_settings_title"
            android:textColor="@color/coco_title"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/save_button"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/bg_save_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="82dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/action_save"
            android:textColor="@color/coco_title"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <LinearLayout style="@style/CocoFormSection">
                <TextView
                    style="@style/CocoSectionTitle"
                    android:text="@string/section_app_mode" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/field_app_mode" />

                <TextView
                    android:id="@+id/app_mode_select"
                    style="@style/CocoFormSelect"
                    android:text="vpn" />
            </LinearLayout>

            <LinearLayout style="@style/CocoFormSection">
                <TextView
                    style="@style/CocoSectionTitle"
                    android:text="@string/section_local_inbounds" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/field_listen" />

                <EditText
                    android:id="@+id/listen_input"
                    style="@style/CocoFormEdit"
                    android:inputType="text"
                    android:text="127.0.0.1" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/field_inbounds" />

                <TextView
                    android:id="@+id/inbounds_select"
                    style="@style/CocoFormSelect"
                    android:text="socks" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/field_socks_port" />

                <EditText
                    android:id="@+id/socks_port_input"
                    style="@style/CocoFormEdit"
                    android:inputType="number"
                    android:text="10809" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/field_http_port" />

                <EditText
                    android:id="@+id/http_port_input"
                    style="@style/CocoFormEdit"
                    android:inputType="number"
                    android:text="10809" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/field_internal_port" />

                <EditText
                    android:id="@+id/internal_port_input"
                    style="@style/CocoFormEdit"
                    android:inputType="number"
                    android:text="10990" />
            </LinearLayout>

            <LinearLayout style="@style/CocoFormSection">
                <TextView
                    style="@style/CocoSectionTitle"
                    android:text="@string/section_routing" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/field_domain_strategy" />

                <TextView
                    android:id="@+id/domain_strategy_select"
                    style="@style/CocoFormSelect"
                    android:text="IPIfNonMatch" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/field_dns_servers" />

                <EditText
                    android:id="@+id/dns_servers_input"
                    style="@style/CocoFormEdit"
                    android:hint="@string/field_dns_servers_hint"
                    android:text="1.1.1.1 8.8.8.8" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/field_domestic_dns_servers" />

                <EditText
                    android:id="@+id/domestic_dns_servers_input"
                    style="@style/CocoFormEdit"
                    android:hint="@string/field_domestic_dns_servers_hint" />

                <Switch
                    android:id="@+id/use_ipv4_switch"
                    style="@style/CocoFormSwitch"
                    android:checked="true"
                    android:text="@string/field_use_ipv4" />

                <Switch
                    android:id="@+id/bypass_private_switch"
                    style="@style/CocoFormSwitch"
                    android:checked="true"
                    android:text="@string/field_bypass_private" />

                <Switch
                    android:id="@+id/block_udp443_switch"
                    style="@style/CocoFormSwitch"
                    android:text="@string/field_block_udp443" />

                <Switch
                    android:id="@+id/sniff_route_only_switch"
                    style="@style/CocoFormSwitch"
                    android:checked="true"
                    android:text="@string/field_sniff_route_only" />
            </LinearLayout>

            <LinearLayout style="@style/CocoFormSection">
                <TextView
                    style="@style/CocoSectionTitle"
                    android:text="@string/section_runtime" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/field_xray_bin" />

                <EditText
                    android:id="@+id/xray_bin_input"
                    style="@style/CocoFormEdit"
                    android:text="AndroidLibXrayLite" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/field_loglevel" />

                <TextView
                    android:id="@+id/loglevel_select"
                    style="@style/CocoFormSelect"
                    android:text="warning" />

                <Switch
                    android:id="@+id/no_run_switch"
                    style="@style/CocoFormSwitch"
                    android:text="@string/field_no_run" />

                <Switch
                    android:id="@+id/once_switch"
                    style="@style/CocoFormSwitch"
                    android:text="@string/field_once" />

                <Switch
                    android:id="@+id/print_config_switch"
                    style="@style/CocoFormSwitch"
                    android:text="@string/field_print_config" />
            </LinearLayout>

            <LinearLayout style="@style/CocoFormSection">
                <TextView
                    style="@style/CocoSectionTitle"
                    android:text="@string/section_logs" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/field_xray_loglevel" />

                <TextView
                    android:id="@+id/xray_loglevel_select"
                    style="@style/CocoFormSelect"
                    android:text="warning" />

                <Switch
                    android:id="@+id/xray_access_logs_switch"
                    style="@style/CocoFormSwitch"
                    android:text="@string/field_xray_access_logs" />

                <Switch
                    android:id="@+id/suppress_noisy_logs_switch"
                    style="@style/CocoFormSwitch"
                    android:checked="true"
                    android:text="@string/field_suppress_noisy_logs" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/field_auto_trim_logs_mb" />

                <EditText
                    android:id="@+id/auto_trim_logs_mb_input"
                    style="@style/CocoFormEdit"
                    android:inputType="numberDecimal"
                    android:text="5" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
