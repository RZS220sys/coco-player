<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:background="@drawable/bg_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="@dimen/icon_button_size"
            android:layout_height="@dimen/icon_button_size"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_back"
            android:padding="10dp"
            android:src="@drawable/ic_back_24" />

        <TextView
            android:id="@+id/title_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans"
            android:includeFontPadding="false"
            android:text="@string/screen_routing_rule_editor_title"
            android:textColor="@color/coco_title"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/save_button"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/bg_save_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="82dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/action_save"
            android:textColor="@color/coco_title"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <LinearLayout style="@style/CocoFormSection">
                <TextView
                    style="@style/CocoSectionTitle"
                    android:text="@string/routing_rule_info_section" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/routing_rule_name" />

                <EditText
                    android:id="@+id/rule_name_input"
                    style="@style/CocoFormEdit"
                    android:inputType="text"
                    android:hint="@string/routing_rule_name_hint" />

                <Switch
                    android:id="@+id/rule_enabled_switch"
                    style="@style/CocoFormSwitch"
                    android:text="@string/routing_rule_enabled" />
            </LinearLayout>

            <LinearLayout style="@style/CocoFormSection">
                <TextView
                    style="@style/CocoSectionTitle"
                    android:text="@string/routing_rule_action_section" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/routing_rule_outbound_tag" />

                <TextView
                    android:id="@+id/outbound_tag_select"
                    style="@style/CocoFormSelect"
                    android:text="proxy" />
            </LinearLayout>

            <LinearLayout style="@style/CocoFormSection">
                <TextView
                    style="@style/CocoSectionTitle"
                    android:text="@string/routing_rule_scope_section" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/routing_rule_port" />

                <EditText
                    android:id="@+id/port_input"
                    style="@style/CocoFormEdit"
                    android:inputType="text"
                    android:hint="@string/routing_rule_port_hint" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/routing_rule_network" />

                <TextView
                    android:id="@+id/network_select"
                    style="@style/CocoFormSelect" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/routing_rule_protocol" />

                <LinearLayout
                    android:id="@+id/protocol_choices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:orientation="vertical"
                    android:paddingTop="2dp" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/routing_rule_inbound_tag" />

                <EditText
                    android:id="@+id/inbound_tag_input"
                    style="@style/CocoFormEditMultiline"
                    android:hint="@string/routing_rule_inbound_tag_hint" />
            </LinearLayout>

            <LinearLayout style="@style/CocoFormSection">
                <TextView
                    style="@style/CocoSectionTitle"
                    android:text="@string/routing_rule_destinations_section" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/routing_rule_domain" />

                <LinearLayout
                    android:id="@+id/domain_tags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_form_field"
                    android:minHeight="96dp"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="4dp" />

                <TextView
                    style="@style/CocoFieldLabel"
                    android:text="@string/routing_rule_ip" />

                <LinearLayout
                    android:id="@+id/ip_tags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_form_field"
                    android:minHeight="96dp"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="4dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
